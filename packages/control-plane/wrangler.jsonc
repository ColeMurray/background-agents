// wrangler.jsonc — local dev config (Terraform manages production)
{
  "name": "open-inspect-control-plane",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-10",
  "compatibility_flags": ["nodejs_compat"],
  // Build before starting dev server. The build script externalizes
  // @cloudflare/sandbox, and we provide a local shim via alias.
  "build": {
    "command": "npm run build",
    "watch_dir": "src"
  },
  "alias": {
    "@cloudflare/sandbox": "./shims/cloudflare-sandbox.js"
  },

  // NOTE: containers config is for production deploy only.
  // wrangler dev does not support containers — the SANDBOX_CONTAINER
  // DO binding still works but won't start real containers locally.
  //
  // "containers": [
  //   {
  //     "class_name": "SandboxContainer",
  //     "image": "./Dockerfile.sandbox",
  //     "instance_type": "standard-3",
  //     "max_instances": 10
  //   }
  // ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION", "class_name": "SessionDO" },
      { "name": "SCHEDULER", "class_name": "SchedulerDO" },
      { "name": "SANDBOX_CONTAINER", "class_name": "SandboxContainer" }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "SchedulerDO"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["SandboxContainer"]
    }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "33575f50-8ec3-4056-a368-f216c12cbc9f",
      "database_name": "open-inspect-jdunn"
    }
  ],

  "kv_namespaces": [{ "binding": "REPOS_CACHE", "id": "02a7cfab1c8b4479bb4ffea0962b345f" }]
}
